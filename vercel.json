{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/herbs", "destination": "/index.html" },
    { "source": "/plants-for-tea", "destination": "/index.html" },
    { "source": "/plants-for-skin", "destination": "/index.html" },
    { "source": "/easy-houseplants", "destination": "/index.html" },
    { "source": "/vegetables-beginners", "destination": "/index.html" },
    { "source": "/plants-for-balcony", "destination": "/index.html" },
    { "source": "/plants/:slug", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/:file.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
